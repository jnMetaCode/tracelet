    "examples",
    "README.md"
  ],
  "keywords": [
    "ai",
    "agents",
    "observability",
    "opentelemetry",
    "otel",
    "tracing",
    "llm",
    "devtools",
    "local-first",
    "debugging",
    "langchain",
    "vercel-ai-sdk"
  ],
